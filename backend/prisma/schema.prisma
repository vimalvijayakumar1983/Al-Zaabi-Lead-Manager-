generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization Types ─────────────────────────────────────────

enum OrgType {
  GROUP
  DIVISION
}

// ─── Multi-Tenant Organization ───────────────────────────────────

model Organization {
  id             String   @id @default(uuid())
  name           String
  tradeName      String?
  domain         String?  @unique
  logo           String?
  primaryColor   String   @default("#6366f1")
  secondaryColor String   @default("#1e293b")
  type           OrgType  @default(DIVISION)
  plan           Plan     @default(FREE)
  settings       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parentId       String?
  parent         Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children       Organization[] @relation("OrgHierarchy")

  users             User[]
  leads             Lead[]
  pipelineStages    PipelineStage[]
  campaigns         Campaign[]
  automationRules   AutomationRule[]
  customFields      CustomField[]
  tags              Tag[]
  webhooks          Webhook[]
  auditLogs         AuditLog[]
  importHistory     ImportHistory[]
  notifications     Notification[]
  integrations      Integration[]
  erpSyncStates     ErpSyncState[]
  erpExternalRefs   ErpExternalRef[]
  erpJobRuns        ErpJobRun[]
  erpRequestAudits  ErpRequestAudit[]
  erpDataAccessLogs ErpDataAccessLog[]
  apiKeys           ApiKey[]
  contacts          Contact[]
  deals             Deal[]
  divisionMemberships DivisionMembership[] @relation("DivisionMembers")
  customRoles         CustomRole[]
  savedViews          SavedView[]
  reportDefinitions   ReportDefinition[]
  whatsAppMessageTemplates WhatsAppMessageTemplate[]
  whatsAppBroadcastLists   WhatsAppBroadcastList[]
  whatsAppBroadcastRuns    WhatsAppBroadcastRun[]

  @@index([parentId])
  @@map("organizations")
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

/// Cached Meta message templates for WhatsApp Business (per division org).
model WhatsAppMessageTemplate {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  waTemplateId   String
  name           String
  language       String
  status         String?
  category       String?
  rejectedReason String?
  components     Json?
  lastSyncedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, waTemplateId])
  @@index([organizationId, name])
  @@map("whatsapp_message_templates")
}

/// Audience list for WhatsApp broadcasts (members imported via Import Center).
model WhatsAppBroadcastList {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  /// Optional stable key for integrations / filters (unique per org when set).
  slug           String?
  memberCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leads WhatsAppBroadcastListLead[]
  broadcasts WhatsAppBroadcastRun[]

  @@unique([organizationId, slug])
  @@index([organizationId, createdAt])
  @@map("whatsapp_broadcast_lists")
}

model WhatsAppBroadcastRun {
  id               String   @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listId           String
  list             WhatsAppBroadcastList @relation(fields: [listId], references: [id], onDelete: Cascade)
  requestedById    String?
  requestedBy      User?    @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  mode             String   @default("NOW") // NOW | LATER
  status           String   @default("SCHEDULED") // SCHEDULED | RUNNING | COMPLETED | FAILED | CANCELLED
  templateId       String?
  templateName     String
  templateLanguage String
  variables        Json     @default("{}")
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  totalRecipients  Int      @default(0)
  sentCount        Int      @default(0)
  deliveredCount   Int      @default(0)
  readCount        Int      @default(0)
  repliedCount     Int      @default(0)
  failedCount      Int      @default(0)
  lastError        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  recipients WhatsAppBroadcastRecipient[]

  @@index([organizationId, status, scheduledAt])
  @@index([listId, createdAt])
  @@map("whatsapp_broadcast_runs")
}

model WhatsAppBroadcastRecipient {
  id           String   @id @default(uuid())
  broadcastId  String
  broadcast    WhatsAppBroadcastRun @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  phone        String
  status        String    @default("PENDING") // PENDING | SENT | DELIVERED | READ | FAILED
  waMessageId   String?
  error         String?
  attemptCount  Int       @default(0)
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([broadcastId, leadId])
  @@index([broadcastId, status])
  @@index([waMessageId])
  @@index([leadId])
  @@map("whatsapp_broadcast_recipients")
}

/// Join table: broadcast list recipients are leads only (single source of truth).
model WhatsAppBroadcastListLead {
  id        String   @id @default(uuid())
  listId    String
  list      WhatsAppBroadcastList @relation(fields: [listId], references: [id], onDelete: Cascade)
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([listId, leadId])
  @@index([listId])
  @@index([leadId])
  @@map("whatsapp_broadcast_list_leads")
}

// ─── Users & Access Control ──────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash    String
  resetToken      String?
  resetTokenExpiry DateTime?
  firstName      String
  lastName       String
  role           Role     @default(SALES_REP)
  avatar         String?
  phone          String?
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedLeads  Lead[]          @relation("AssignedTo")
  createdLeads   Lead[]          @relation("CreatedBy")
  activities     LeadActivity[]
  notes          LeadNote[]
  tasks          Task[]          @relation("TaskAssignee")
  createdTasks   Task[]          @relation("TaskCreator")
  communications Communication[]
  callLogs       CallLog[]
  auditLogs      AuditLog[]
  imports        ImportHistory[]
  notifications         Notification[] @relation("NotificationRecipient")
  actedNotifications    Notification[] @relation("NotificationActor")
  notificationPreference NotificationPreference?
  createdIntegrations   Integration[]  @relation("IntegrationCreator")
  divisionMemberships  DivisionMembership[]
  ownedContacts         Contact[]      @relation("ContactOwner")
  createdContacts       Contact[]      @relation("ContactCreatedBy")
  contactActivities     ContactActivity[]
  contactNotes          ContactNote[]
  ownedDeals            Deal[]         @relation("DealOwner")

  customRoleId         String?
  customRole           CustomRole?    @relation("UserCustomRole", fields: [customRoleId], references: [id], onDelete: SetNull)
  createdCustomRoles   CustomRole[]   @relation("CustomRoleCreator")
  createdViews         SavedView[]    @relation("ViewCreator")
  createdReports       ReportDefinition[] @relation("ReportCreator")
  erpDataAccessLogs    ErpDataAccessLog[] @relation("ErpDataAccessLogAccessor")
  requestedBroadcastRuns WhatsAppBroadcastRun[]

  @@index([organizationId])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES_REP
  VIEWER
}

// ─── Leads ───────────────────────────────────────────────────────

model Lead {
  id              String     @id @default(uuid())
  firstName       String
  lastName        String     @default("")
  email           String?
  phone           String?
  company         String?
  jobTitle        String?
  source          LeadSource @default(MANUAL)
  sourceDetail    String?
  status          LeadStatus @default(NEW)
  score           Int        @default(0)
  budget          Decimal?   @db.Decimal(12, 2)
  productInterest String?
  location        String?
  campaign        String?
  website         String?
  customData      Json       @default("{}")
  aiSummary       String?
  conversionProb  Float?
  isArchived      Boolean    @default(false)
  wonAt           DateTime?
  lostAt          DateTime?
  lostReason      String?
  doNotCall       Boolean   @default(false)
  doNotCallAt     DateTime?
  doNotCallById   String?

  // ── WhatsApp Broadcast Opt-out ──
  whatsappOptOut    Boolean   @default(false)
  whatsappOptOutAt  DateTime?
  whatsappOptOutById String?

  // ── SLA Tracking ──
  firstRespondedAt  DateTime?            // When the assigned user first interacted with this lead
  slaStatus         LeadSLAStatus @default(ON_TIME)
  escalationLevel   Int           @default(0)  // 0=normal, 1=reminded, 2=escalated, 3=reassigned
  lastEscalatedAt   DateTime?            // Last time an SLA escalation action was taken
  slaBreachedAt     DateTime?            // When the SLA was first breached

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedToId    String?
  assignedTo      User?    @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById     String?
  createdBy       User?    @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  stageId         String?
  stage           PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  stageOrder      Int      @default(0)

  activities      LeadActivity[]
  notes           LeadNote[]
  tasks           Task[]
  communications  Communication[]
  callLogs        CallLog[]
  tags            LeadTag[]
  attachments     Attachment[]
  convertedContact Contact? @relation("ConvertedContact")
  broadcastListLinks WhatsAppBroadcastListLead[]
  broadcastRecipients WhatsAppBroadcastRecipient[]

  @@index([organizationId, status])
  @@index([organizationId, source])
  @@index([organizationId, assignedToId])
  @@index([organizationId, stageId])
  @@index([email])
  @@index([phone])
  @@index([organizationId, slaStatus])
  @@map("leads")
}

enum LeadSource {
  WEBSITE_FORM
  LIVE_CHAT
  LANDING_PAGE
  WHATSAPP
  FACEBOOK_ADS
  GOOGLE_ADS
  TIKTOK_ADS
  MANUAL
  CSV_IMPORT
  API
  REFERRAL
  EMAIL
  PHONE
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadSLAStatus {
  ON_TIME        // Within SLA thresholds
  AT_RISK        // Approaching SLA breach (e.g. 75% of threshold elapsed)
  BREACHED       // SLA threshold exceeded, action pending
  ESCALATED      // Escalation action taken (reminded/reassigned)
  RESPONDED      // User responded within SLA
}

// ─── Contacts ───────────────────────────────────────────────────

model Contact {
  id              String        @id @default(uuid())
  firstName       String
  lastName        String     @default("")
  email           String?
  phone           String?
  mobile          String?
  company         String?
  jobTitle        String?
  department      String?
  source          LeadSource    @default(MANUAL)
  lifecycle       ContactLifecycle @default(SUBSCRIBER)
  type            ContactType   @default(PROSPECT)
  salutation      String?       // Mr., Mrs., Dr., etc.
  dateOfBirth     DateTime?
  website         String?
  linkedin        String?
  twitter         String?
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  description     String?
  score           Int           @default(0)
  lastContactedAt DateTime?
  doNotEmail      Boolean       @default(false)
  doNotCall       Boolean       @default(false)
  hasOptedOutEmail Boolean      @default(false)
  customData      Json          @default("{}")
  isArchived      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ownerId         String?
  owner           User?    @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdById     String?
  createdBy       User?    @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  convertedFromLeadId String? @unique
  convertedFromLead   Lead?   @relation("ConvertedContact", fields: [convertedFromLeadId], references: [id], onDelete: SetNull)

  activities      ContactActivity[]
  notes           ContactNote[]
  tasks           Task[]        @relation("ContactTasks")
  tags            ContactTag[]
  deals           Deal[]

  @@index([organizationId, lifecycle])
  @@index([organizationId, type])
  @@index([organizationId, ownerId])
  @@index([email])
  @@index([phone])
  @@map("contacts")
}

enum ContactLifecycle {
  SUBSCRIBER
  LEAD
  MARKETING_QUALIFIED
  SALES_QUALIFIED
  OPPORTUNITY
  CUSTOMER
  EVANGELIST
  OTHER
}

enum ContactType {
  PROSPECT
  CUSTOMER
  PARTNER
  VENDOR
  INFLUENCER
  OTHER
}

model ContactActivity {
  id          String       @id @default(uuid())
  type        ActivityType
  description String
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())

  contactId   String
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([contactId, createdAt])
  @@map("contact_activities")
}

model ContactNote {
  id        String   @id @default(uuid())
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_notes")
}

model ContactTag {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tagId     String
  tag       Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model Deal {
  id          String     @id @default(uuid())
  name        String
  amount      Decimal?   @db.Decimal(12, 2)
  stage       String     @default("QUALIFICATION")
  probability Int        @default(0)
  closeDate   DateTime?
  description String?
  status      DealStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  contactId      String
  contact        Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ownerId        String?
  owner          User?   @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([organizationId, status])
  @@map("deals")
}

enum DealStatus {
  OPEN
  WON
  LOST
}

// ─── Pipeline ────────────────────────────────────────────────────

model PipelineStage {
  id             String   @id @default(uuid())
  name           String
  order          Int
  color          String   @default("#6366f1")
  isDefault      Boolean  @default(false)
  isWonStage     Boolean  @default(false)
  isLostStage    Boolean  @default(false)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  leads          Lead[]

  @@unique([organizationId, order])
  @@map("pipeline_stages")
}

// ─── Call Logs ──────────────────────────────────────────────────

model CallLog {
  id              String          @id @default(uuid())
  disposition     CallDisposition
  notes           String?
  duration        Int?            // call duration in seconds
  callbackDate    DateTime?       // when to call back (for CALLBACK disposition)
  meetingDate     DateTime?       // scheduled meeting date (for MEETING_ARRANGED)
  appointmentDate DateTime?       // booked appointment date (for APPOINTMENT_BOOKED)
  metadata        Json            @default("{}")
  createdAt       DateTime        @default(now())

  leadId          String
  lead            Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId          String?
  user            User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Auto-created follow-up task (if any)
  followUpTaskId  String?

  @@index([leadId, createdAt])
  @@index([disposition])
  @@map("call_logs")
}

enum CallDisposition {
  CALLBACK          // Customer asked to call back later (legacy — use CALL_LATER / CALL_AGAIN)
  CALL_LATER        // Client requested call at a specific date/time (mandatory schedule)
  CALL_AGAIN        // Call again anytime — no specific schedule required
  WILL_CALL_US_AGAIN // Client said they will call back; place in soft engagement loop
  MEETING_ARRANGED  // Meeting has been scheduled
  APPOINTMENT_BOOKED // Appointment confirmed
  INTERESTED        // Customer showed interest, send info
  NOT_INTERESTED    // Customer not interested
  ALREADY_COMPLETED_SERVICES // Service already completed; track inside vs outside center
  NO_ANSWER         // No one picked up
  VOICEMAIL_LEFT    // Left voicemail
  WRONG_NUMBER      // Wrong contact number
  BUSY              // Line busy, try again
  GATEKEEPER        // Reached gatekeeper, not decision maker
  FOLLOW_UP_EMAIL   // Customer requested info via email
  QUALIFIED         // Lead qualified during call
  PROPOSAL_REQUESTED // Customer requested a proposal
  DO_NOT_CALL       // Customer asked not to be called
  OTHER             // Other outcome
}

// ─── Activities ──────────────────────────────────────────────────

model LeadActivity {
  id          String       @id @default(uuid())
  type        ActivityType
  description String
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())

  leadId      String
  lead        Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

enum ActivityType {
  STATUS_CHANGE
  STAGE_CHANGE
  NOTE_ADDED
  TASK_CREATED
  TASK_COMPLETED
  EMAIL_SENT
  EMAIL_RECEIVED
  CALL_MADE
  CALL_RECEIVED
  WHATSAPP_SENT
  WHATSAPP_RECEIVED
  MEETING_SCHEDULED
  ASSIGNMENT_CHANGED
  SCORE_UPDATED
  ATTACHMENT_ADDED
  SLA_REMINDER_SENT
  SLA_ESCALATED
  SLA_REASSIGNED
  SLA_BREACHED
  CUSTOM
}

// ─── Notes ───────────────────────────────────────────────────────

model LeadNote {
  id        String   @id @default(uuid())
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId    String
  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_notes")
}

// ─── Tasks & Follow-ups ─────────────────────────────────────────

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  type        TaskType
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(PENDING)
  dueAt       DateTime
  completedAt DateTime?
  isRecurring Boolean    @default(false)
  recurRule   String?
  reminder    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  leadId      String?
  lead        Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  contactId   String?
  contact     Contact? @relation("ContactTasks", fields: [contactId], references: [id], onDelete: Cascade)

  assigneeId  String
  assignee    User @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([assigneeId, status])
  @@index([dueAt])
  @@index([reminder])
  @@map("tasks")
}

enum TaskType {
  FOLLOW_UP_CALL
  MEETING
  EMAIL
  WHATSAPP
  DEMO
  PROPOSAL
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Communications ──────────────────────────────────────────────

model Communication {
  id          String            @id @default(uuid())
  channel     CommunicationChannel
  direction   Direction
  subject     String?
  body        String
  metadata    Json              @default("{}")
  isEdited    Boolean           @default(false)
  isDeleted   Boolean           @default(false)
  isRead      Boolean           @default(false)
  readAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  leadId      String
  lead        Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId      String?
  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([leadId, isRead, direction])
  @@map("communications")
}

enum CommunicationChannel {
  EMAIL
  WHATSAPP
  SMS
  PHONE
  CHAT
}

enum Direction {
  INBOUND
  OUTBOUND
}

// ─── Campaigns ───────────────────────────────────────────────────

model Campaign {
  id             String         @id @default(uuid())
  name           String
  type           CampaignType
  status         CampaignStatus @default(DRAFT)
  budget         Decimal?       @db.Decimal(12, 2)
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  integrations   Integration[]

  @@index([organizationId])
  @@map("campaigns")
}

enum CampaignType {
  FACEBOOK_ADS
  GOOGLE_ADS
  EMAIL
  WHATSAPP
  LANDING_PAGE
  REFERRAL
  TIKTOK_ADS
  WEBSITE_FORM
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum RecycleEntityType {
  LEAD
  CONTACT
  TASK
  CAMPAIGN
}

model RecycleBinItem {
  id               String            @id @default(uuid())
  entityType       RecycleEntityType
  entityId         String
  entityLabel      String?
  organizationId   String
  deletedById      String?
  recordOwnerId    String?
  recordAssigneeId String?
  recordCreatorId  String?
  deletedAt        DateTime          @default(now())
  purgeAt          DateTime
  metadata         Json              @default("{}")
  snapshot         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([entityType, entityId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, purgeAt])
  @@index([entityType, organizationId])
  @@index([recordOwnerId])
  @@index([recordAssigneeId])
  @@index([recordCreatorId])
  @@map("recycle_bin_items")
}

// ─── Tags ────────────────────────────────────────────────────────

model Tag {
  id             String   @id @default(uuid())
  name           String
  color          String   @default("#6366f1")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  leads          LeadTag[]
  contacts       ContactTag[]

  @@unique([organizationId, name])
  @@map("tags")
}

model LeadTag {
  leadId String
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  tagId  String
  tag    Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("lead_tags")
}

// ─── Attachments ─────────────────────────────────────────────────

model Attachment {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  size      Int
  url       String
  data      String?  @db.Text
  storageKey String?
  createdAt DateTime @default(now())

  leadId    String
  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ─── Custom Fields ───────────────────────────────────────────────

model CustomField {
  id             String    @id @default(uuid())
  name           String
  label          String
  type           FieldType
  options        Json?
  isRequired     Boolean   @default(false)
  order          Int       @default(0)
  showInList     Boolean   @default(true)
  showInDetail   Boolean   @default(true)
  description    String?
  placeholder    String?
  defaultValue   String?

  divisionId     String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("custom_fields")
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  BOOLEAN
  URL
  EMAIL
  PHONE
  TEXTAREA
  CURRENCY
}

// ─── Automation Rules ────────────────────────────────────────────

model AutomationRule {
  id             String              @id @default(uuid())
  name           String
  description    String?
  trigger        AutomationTrigger
  conditions     Json
  actions        Json
  isActive       Boolean             @default(true)
  isTemplate     Boolean             @default(false)
  executionCount Int                 @default(0)
  lastExecutedAt DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs           AutomationLog[]

  @@index([organizationId, isActive])
  @@index([organizationId, isTemplate])
  @@map("automation_rules")
}

model AutomationLog {
  id               String   @id @default(uuid())
  status           String   @default("success") // success, failed, skipped
  trigger          String
  conditionsMet    Boolean  @default(true)
  actionsExecuted  Json     @default("[]")
  error            String?
  executionTimeMs  Int      @default(0)
  leadId           String?
  leadName         String?
  createdAt        DateTime @default(now())

  ruleId           String
  rule             AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, createdAt])
  @@index([createdAt])
  @@map("automation_logs")
}

enum AutomationTrigger {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  LEAD_STAGE_CHANGED
  LEAD_ASSIGNED
  LEAD_SCORE_CHANGED
  LEAD_INACTIVE
  LEAD_SLA_WARNING
  LEAD_SLA_BREACHED
  LEAD_SLA_ESCALATED
  TASK_DUE
  TASK_OVERDUE
  LEAD_CREATED_TIME_ELAPSED
  LEAD_UPDATED_TIME_ELAPSED
}

// ─── Webhooks ────────────────────────────────────────────────────

model Webhook {
  id             String   @id @default(uuid())
  url            String
  events         Json
  secret         String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

// ─── Import History ─────────────────────────────────────────────

model ImportHistory {
  id              String       @id @default(uuid())
  module          String       // leads, campaigns
  fileName        String
  fileSize        Int
  totalRows       Int          @default(0)
  importedCount   Int          @default(0)
  skippedCount    Int          @default(0)
  updatedCount    Int          @default(0)
  duplicateCount  Int          @default(0)
  status          ImportStatus @default(PROCESSING)
  fieldMapping    Json         @default("{}") // { csvColumn: crmField }
  duplicateAction String       @default("skip") // skip, overwrite, clone
  duplicateField  String?      // email, phone, etc.
  errors          Json         @default("[]")
  importedIds     Json         @default("[]") // array of created record IDs for undo
  undoneAt        DateTime?
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId          String?
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("import_history")
}

enum ImportStatus {
  PROCESSING
  COMPLETED
  FAILED
  UNDONE
}

// ─── Audit Logs ──────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  action         String
  entity         String
  entityId       String?
  oldData        Json?
  newData        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId         String?
  user           User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─── Notifications ──────────────────────────────────────────────

model Notification {
  id             String   @id @default(uuid())
  type           String
  title          String
  message        String
  isRead         Boolean  @default(false)
  isArchived     Boolean  @default(false)
  readAt         DateTime?
  entityType     String?
  entityId       String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  actorId        String?
  actor          User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, isArchived])
  @@index([organizationId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id          String   @id @default(uuid())
  preferences Json     @default("{}")
  updatedAt   DateTime @updatedAt

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─── Integrations ───────────────────────────────────────────────

model Integration {
  id             String   @id @default(uuid())
  platform       String
  status         String   @default("disconnected")
  providerKey    String?  @map("provider_key")
  protocol       String?
  syncMode       String?  @map("sync_mode")
  deploymentType String?  @map("deployment_type")
  apiVersion     String?  @map("api_version")
  capabilities   Json     @default("{}")
  complianceProfile String? @map("compliance_profile")
  requiresComplianceLog Boolean @default(false) @map("requires_compliance_log")
  credentials    Json     @default("{}")
  config         Json     @default("{}")
  lastSyncAt     DateTime? @map("last_sync_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  campaignId     String?  @map("campaign_id")
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  createdById    String?  @map("created_by")
  createdBy      User?    @relation("IntegrationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  logs           IntegrationLog[]
  erpSyncStates  ErpSyncState[]
  erpExternalRefs ErpExternalRef[]
  erpJobRuns     ErpJobRun[]
  erpRequestAudits ErpRequestAudit[]
  erpDataAccessLogs ErpDataAccessLog[]

  @@index([organizationId, platform])
  @@index([organizationId, providerKey])
  @@map("integrations")
}

model IntegrationLog {
  id             String   @id @default(uuid())
  action         String
  payload        Json     @default("{}")
  status         String   @default("success")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  integrationId  String   @map("integration_id")
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  leadId         String?  @map("lead_id")

  @@index([integrationId, createdAt])
  @@map("integration_logs")
}

model ErpSyncState {
  id             String   @id @default(uuid())
  entityType     String   @map("entity_type")
  cursor         String?
  watermark      DateTime? @map("watermark")
  lastSyncedAt   DateTime? @map("last_synced_at")
  status         String   @default("idle")
  lastError      String?  @map("last_error")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  integrationId  String   @map("integration_id")
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, integrationId, entityType])
  @@index([organizationId, integrationId])
  @@map("erp_sync_states")
}

model ErpExternalRef {
  id             String   @id @default(uuid())
  entityType     String   @map("entity_type")
  crmEntityId    String   @map("crm_entity_id")
  externalId     String   @map("external_id")
  externalPayload Json?   @map("external_payload")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  integrationId  String   @map("integration_id")
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, entityType, externalId])
  @@index([organizationId, entityType, crmEntityId])
  @@map("erp_external_refs")
}

model ErpJobRun {
  id             String   @id @default(uuid())
  jobType        String   @map("job_type")
  status         String   @default("pending")
  requestPayload Json?    @map("request_payload")
  responsePayload Json?   @map("response_payload")
  retryCount     Int      @default(0) @map("retry_count")
  startedAt      DateTime? @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  integrationId  String?  @map("integration_id")
  integration    Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([organizationId, jobType, status])
  @@map("erp_job_runs")
}

model ErpRequestAudit {
  id             String   @id @default(uuid())
  action         String
  requestPayload Json?    @map("request_payload")
  responsePayload Json?   @map("response_payload")
  statusCode     Int?     @map("status_code")
  latencyMs      Int?     @map("latency_ms")
  retryable      Boolean  @default(false)
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  integrationId  String?  @map("integration_id")
  integration    Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([integrationId, createdAt])
  @@map("erp_request_audits")
}

model ErpDataAccessLog {
  id             String   @id @default(uuid())
  entityType     String   @map("entity_type")
  externalId     String?  @map("external_id")
  accessReason   String?  @map("access_reason")
  accessContext  Json?    @map("access_context")
  createdAt      DateTime @default(now()) @map("created_at")

  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  integrationId  String?  @map("integration_id")
  integration    Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  accessedById   String?  @map("accessed_by_id")
  accessedBy     User?    @relation("ErpDataAccessLogAccessor", fields: [accessedById], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, createdAt])
  @@index([integrationId, createdAt])
  @@map("erp_data_access_logs")
}

// ─── API Keys ───────────────────────────────────────────────────

model ApiKey {
  id             String   @id @default(uuid())
  key            String   @unique
  name           String
  isActive       Boolean  @default(true) @map("is_active")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([key, isActive])
  @@map("api_keys")
}

// ─── Division Memberships ────────────────────────────────────────
// Allows users to belong to multiple divisions with different roles

model DivisionMembership {
  id         String   @id @default(uuid())
  userId     String
  divisionId String
  role       Role     @default(SALES_REP)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  division   Organization @relation("DivisionMembers", fields: [divisionId], references: [id], onDelete: Cascade)

  @@unique([userId, divisionId])
  @@index([userId])
  @@index([divisionId])
  @@map("division_memberships")
}


// ─── Custom Roles ────────────────────────────────────────────────

model CustomRole {
  id             String   @id @default(uuid())
  name           String
  description    String?
  color          String   @default("#6366f1")
  icon           String   @default("shield")
  permissions    Json     @default("{}")
  isSystem       Boolean  @default(false)
  baseRole       Role     @default(SALES_REP)
  level          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById    String?
  createdBy      User?    @relation("CustomRoleCreator", fields: [createdById], references: [id], onDelete: SetNull)

  users          User[]   @relation("UserCustomRole")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("custom_roles")
}

// ─── Saved Views ─────────────────────────────────────────────────

model SavedView {
  id               String   @id @default(uuid())
  name             String
  icon             String?
  filters          Json     @default("{}")
  sortBy           String?
  sortOrder        String?  @default("desc")
  columns          Json?
  visibility       String   @default("everyone") // everyone, private, specific_users, specific_roles
  visibleToUsers   String[] @default([])
  visibleToRoles   String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  divisionId       String?

  createdById      String
  createdBy        User @relation("ViewCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([divisionId])
  @@index([createdById])
  @@map("saved_views")
}

model ReportDefinition {
  id             String   @id @default(uuid())
  name           String
  description    String?
  dataset        String
  config         Json     @default("{}")
  visibility     String   @default("everyone") // everyone, private, specific_users, specific_roles
  visibleToUsers String[] @default([])
  visibleToRoles String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  divisionId     String?

  createdById    String
  createdBy      User @relation("ReportCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([divisionId])
  @@index([createdById])
  @@map("report_definitions")
}

model EmailSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  smtpHost       String   @default("mail.alzaabigroup.com")
  smtpPort       Int      @default(465)
  smtpSecure     Boolean  @default(true)
  smtpUsername   String   @default("")
  smtpPassword   String   @default("")
  fromEmail      String   @default("")
  fromName       String   @default("Al-Zaabi Lead Manager")
  imapHost       String?  @default("")
  imapPort       Int?     @default(993)
  imapSecure     Boolean? @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("email_settings")
}
