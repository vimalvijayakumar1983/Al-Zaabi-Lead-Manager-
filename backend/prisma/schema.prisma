generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization Types ─────────────────────────────────────────

enum OrgType {
  GROUP
  DIVISION
}

// ─── Multi-Tenant Organization ───────────────────────────────────

model Organization {
  id             String   @id @default(uuid())
  name           String
  tradeName      String?
  domain         String?  @unique
  logo           String?
  primaryColor   String   @default("#6366f1")
  secondaryColor String   @default("#1e293b")
  type           OrgType  @default(DIVISION)
  plan           Plan     @default(FREE)
  settings       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parentId       String?
  parent         Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children       Organization[] @relation("OrgHierarchy")

  users             User[]
  leads             Lead[]
  pipelineStages    PipelineStage[]
  campaigns         Campaign[]
  automationRules   AutomationRule[]
  customFields      CustomField[]
  tags              Tag[]
  webhooks          Webhook[]
  auditLogs         AuditLog[]
  importHistory     ImportHistory[]
  notifications     Notification[]
  integrations      Integration[]
  apiKeys           ApiKey[]

  @@index([parentId])
  @@map("organizations")
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─── Users & Access Control ──────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role     @default(SALES_REP)
  avatar         String?
  phone          String?
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedLeads  Lead[]          @relation("AssignedTo")
  createdLeads   Lead[]          @relation("CreatedBy")
  activities     LeadActivity[]
  notes          LeadNote[]
  tasks          Task[]          @relation("TaskAssignee")
  createdTasks   Task[]          @relation("TaskCreator")
  communications Communication[]
  auditLogs      AuditLog[]
  imports        ImportHistory[]
  notifications         Notification[] @relation("NotificationRecipient")
  actedNotifications    Notification[] @relation("NotificationActor")
  notificationPreference NotificationPreference?
  createdIntegrations   Integration[]  @relation("IntegrationCreator")

  @@index([organizationId])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES_REP
  VIEWER
}

// ─── Leads ───────────────────────────────────────────────────────

model Lead {
  id              String     @id @default(uuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  company         String?
  jobTitle        String?
  source          LeadSource @default(MANUAL)
  status          LeadStatus @default(NEW)
  score           Int        @default(0)
  budget          Decimal?   @db.Decimal(12, 2)
  productInterest String?
  location        String?
  campaign        String?
  website         String?
  customData      Json       @default("{}")
  aiSummary       String?
  conversionProb  Float?
  isArchived      Boolean    @default(false)
  wonAt           DateTime?
  lostAt          DateTime?
  lostReason      String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedToId    String?
  assignedTo      User?    @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById     String?
  createdBy       User?    @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  stageId         String?
  stage           PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  stageOrder      Int      @default(0)

  activities      LeadActivity[]
  notes           LeadNote[]
  tasks           Task[]
  communications  Communication[]
  tags            LeadTag[]
  attachments     Attachment[]

  @@index([organizationId, status])
  @@index([organizationId, source])
  @@index([organizationId, assignedToId])
  @@index([organizationId, stageId])
  @@index([email])
  @@index([phone])
  @@map("leads")
}

enum LeadSource {
  WEBSITE_FORM
  LANDING_PAGE
  WHATSAPP
  FACEBOOK_ADS
  GOOGLE_ADS
  TIKTOK_ADS
  MANUAL
  CSV_IMPORT
  API
  REFERRAL
  EMAIL
  PHONE
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

// ─── Pipeline ────────────────────────────────────────────────────

model PipelineStage {
  id             String   @id @default(uuid())
  name           String
  order          Int
  color          String   @default("#6366f1")
  isDefault      Boolean  @default(false)
  isWonStage     Boolean  @default(false)
  isLostStage    Boolean  @default(false)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  leads          Lead[]

  @@unique([organizationId, order])
  @@map("pipeline_stages")
}

// ─── Activities ──────────────────────────────────────────────────

model LeadActivity {
  id          String       @id @default(uuid())
  type        ActivityType
  description String
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())

  leadId      String
  lead        Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

enum ActivityType {
  STATUS_CHANGE
  STAGE_CHANGE
  NOTE_ADDED
  TASK_CREATED
  TASK_COMPLETED
  EMAIL_SENT
  EMAIL_RECEIVED
  CALL_MADE
  CALL_RECEIVED
  WHATSAPP_SENT
  WHATSAPP_RECEIVED
  MEETING_SCHEDULED
  ASSIGNMENT_CHANGED
  SCORE_UPDATED
  ATTACHMENT_ADDED
  CUSTOM
}

// ─── Notes ───────────────────────────────────────────────────────

model LeadNote {
  id        String   @id @default(uuid())
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId    String
  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_notes")
}

// ─── Tasks & Follow-ups ─────────────────────────────────────────

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  type        TaskType
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(PENDING)
  dueAt       DateTime
  completedAt DateTime?
  isRecurring Boolean    @default(false)
  recurRule   String?
  reminder    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  leadId      String?
  lead        Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assigneeId  String
  assignee    User @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([assigneeId, status])
  @@index([dueAt])
  @@map("tasks")
}

enum TaskType {
  FOLLOW_UP_CALL
  MEETING
  EMAIL
  WHATSAPP
  DEMO
  PROPOSAL
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Communications ──────────────────────────────────────────────

model Communication {
  id          String            @id @default(uuid())
  channel     CommunicationChannel
  direction   Direction
  subject     String?
  body        String
  metadata    Json              @default("{}")
  createdAt   DateTime          @default(now())

  leadId      String
  lead        Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId      String?
  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@map("communications")
}

enum CommunicationChannel {
  EMAIL
  WHATSAPP
  SMS
  PHONE
  CHAT
}

enum Direction {
  INBOUND
  OUTBOUND
}

// ─── Campaigns ───────────────────────────────────────────────────

model Campaign {
  id             String         @id @default(uuid())
  name           String
  type           CampaignType
  status         CampaignStatus @default(DRAFT)
  budget         Decimal?       @db.Decimal(12, 2)
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  integrations   Integration[]

  @@index([organizationId])
  @@map("campaigns")
}

enum CampaignType {
  FACEBOOK_ADS
  GOOGLE_ADS
  EMAIL
  WHATSAPP
  LANDING_PAGE
  REFERRAL
  TIKTOK_ADS
  WEBSITE_FORM
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

// ─── Tags ────────────────────────────────────────────────────────

model Tag {
  id             String   @id @default(uuid())
  name           String
  color          String   @default("#6366f1")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  leads          LeadTag[]

  @@unique([organizationId, name])
  @@map("tags")
}

model LeadTag {
  leadId String
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  tagId  String
  tag    Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("lead_tags")
}

// ─── Attachments ─────────────────────────────────────────────────

model Attachment {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  size      Int
  url       String
  createdAt DateTime @default(now())

  leadId    String
  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ─── Custom Fields ───────────────────────────────────────────────

model CustomField {
  id             String    @id @default(uuid())
  name           String
  label          String
  type           FieldType
  options        Json?
  isRequired     Boolean   @default(false)
  order          Int       @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("custom_fields")
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  BOOLEAN
  URL
  EMAIL
  PHONE
}

// ─── Automation Rules ────────────────────────────────────────────

model AutomationRule {
  id             String              @id @default(uuid())
  name           String
  description    String?
  trigger        AutomationTrigger
  conditions     Json
  actions        Json
  isActive       Boolean             @default(true)
  executionCount Int                 @default(0)
  lastExecutedAt DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@map("automation_rules")
}

enum AutomationTrigger {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  LEAD_STAGE_CHANGED
  LEAD_ASSIGNED
  LEAD_SCORE_CHANGED
  LEAD_INACTIVE
  TASK_DUE
  TASK_OVERDUE
}

// ─── Webhooks ────────────────────────────────────────────────────

model Webhook {
  id             String   @id @default(uuid())
  url            String
  events         Json
  secret         String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

// ─── Import History ─────────────────────────────────────────────

model ImportHistory {
  id              String       @id @default(uuid())
  module          String       // leads, campaigns
  fileName        String
  fileSize        Int
  totalRows       Int          @default(0)
  importedCount   Int          @default(0)
  skippedCount    Int          @default(0)
  updatedCount    Int          @default(0)
  duplicateCount  Int          @default(0)
  status          ImportStatus @default(PROCESSING)
  fieldMapping    Json         @default("{}") // { csvColumn: crmField }
  duplicateAction String       @default("skip") // skip, overwrite, clone
  duplicateField  String?      // email, phone, etc.
  errors          Json         @default("[]")
  importedIds     Json         @default("[]") // array of created record IDs for undo
  undoneAt        DateTime?
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId          String?
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("import_history")
}

enum ImportStatus {
  PROCESSING
  COMPLETED
  FAILED
  UNDONE
}

// ─── Audit Logs ──────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  action         String
  entity         String
  entityId       String
  oldData        Json?
  newData        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId         String?
  user           User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─── Notifications ──────────────────────────────────────────────

model Notification {
  id             String   @id @default(uuid())
  type           String
  title          String
  message        String
  isRead         Boolean  @default(false)
  isArchived     Boolean  @default(false)
  readAt         DateTime?
  entityType     String?
  entityId       String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  actorId        String?
  actor          User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, isArchived])
  @@index([organizationId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id          String   @id @default(uuid())
  preferences Json     @default("{}")
  updatedAt   DateTime @updatedAt

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─── Integrations ───────────────────────────────────────────────

model Integration {
  id             String   @id @default(uuid())
  platform       String
  status         String   @default("disconnected")
  credentials    Json     @default("{}")
  config         Json     @default("{}")
  lastSyncAt     DateTime? @map("last_sync_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  campaignId     String?  @map("campaign_id")
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  createdById    String?  @map("created_by")
  createdBy      User?    @relation("IntegrationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  logs           IntegrationLog[]

  @@index([organizationId, platform])
  @@map("integrations")
}

model IntegrationLog {
  id             String   @id @default(uuid())
  action         String
  payload        Json     @default("{}")
  status         String   @default("success")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  integrationId  String   @map("integration_id")
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  leadId         String?  @map("lead_id")

  @@index([integrationId, createdAt])
  @@map("integration_logs")
}

// ─── API Keys ───────────────────────────────────────────────────

model ApiKey {
  id             String   @id @default(uuid())
  key            String   @unique
  name           String
  isActive       Boolean  @default(true) @map("is_active")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([key, isActive])
  @@map("api_keys")
}
