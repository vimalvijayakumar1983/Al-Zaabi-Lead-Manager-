# Database
# DATABASE_URL="postgresql://postgres:FJrFLFJxvrTvNduZzrgUQkrtiRJEfuNl@shinkansen.proxy.rlwy.net:42931/railway"
# Matches docker-compose.yml postgres service (local dev)
DATABASE_URL="postgresql://leadflow:leadflow_secret@localhost:5432/leadflow?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# Email (SMTP - Outgoing)
SMTP_HOST=mail.alzaabigroup.com
SMTP_PORT=587
SMTP_USER=your-email@alzaabigroup.com
SMTP_PASS=your-password

# Email (IMAP - Incoming)
IMAP_HOST=mail.alzaabigroup.com
IMAP_PORT=993
IMAP_USER=your-email@alzaabigroup.com
IMAP_PASS=your-password
IMAP_SECURITY=ssl

# Email (POP3 - Incoming)
POP3_HOST=mail.alzaabigroup.com
POP3_PORT=995
POP3_USER=your-email@alzaabigroup.com
POP3_PASS=your-password
POP3_SECURITY=ssl

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# Same value as "Verify token" in Meta App → WhatsApp → Configuration → Webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
# Optional: if webhook phone_number_id does not match any division Settings → WhatsApp, save inbound messages to this org UUID (dev / Meta test payloads)
# WHATSAPP_UNMATCHED_FALLBACK_ORG_ID=

# AI / LLM
OPENAI_API_KEY=your-openai-key
AI_MODEL=gpt-4

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Inbox attachments — optional S3-compatible storage (AWS S3, Cloudflare R2, MinIO).
# When unset or incomplete, attachment binaries stay in Postgres (base64) as before.
# S3_BUCKET=
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional — R2/MinIO custom endpoint:
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
# S3_ATTACHMENT_PREFIX=inbox
# S3_SIGNED_URL_TTL_SECONDS=3600

# Webhook Secret
WEBHOOK_SECRET=your-webhook-secret
