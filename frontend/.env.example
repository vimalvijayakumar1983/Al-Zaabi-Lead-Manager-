# Copy to .env.local for local development (not committed).

# Where the Next.js API proxy forwards /api/* (Express backend). MUST be your API base URL,
# NOT this frontend (e.g. do not use http://localhost:3000).
BACKEND_URL=http://localhost:4000/api

# Optional: public URL for client-only fetch (forgot-password, etc.). Usually same /api base as BACKEND_URL locally.
# NEXT_PUBLIC_API_URL=http://localhost:4000/api

# npm run dev uses -p 3000 and (on Windows) stops a prior Next.js on 3000. If something else uses 3000,
# Next may fall back to 3001+ — open the exact "Local: http://localhost:…" URL from the terminal, not a stale tab.
